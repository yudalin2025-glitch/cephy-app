# 数据库连接字符串（默认使用 SQLite 开发）
DATABASE_URL=sqlite:///./cephy_dev.db

# JWT 签名密钥（生产环境请使用足够长的随机字符串）
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Google Gemini API Key（可选，留空则返回 mock 数据）
GEMINI_API_KEY=

# OpenWeatherMap API Key（可选）
OPENWEATHERMAP_API_KEY=

# Apple Sign-In 团队信息（可选）
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# 日志级别
LOG_LEVEL=INFO
